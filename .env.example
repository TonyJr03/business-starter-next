# ═════════════════════════════════════════════════════════════════════════════
# Supabase Configuration
# ═════════════════════════════════════════════════════════════════════════════
# URL del proyecto Supabase
# Formato local: http://127.0.0.1:54321
# Formato production: https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clave anon/pública de Supabase
# Se puede obtener de: Supabase Dashboard > Project Settings > API Keys > anon / public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ═════════════════════════════════════════════════════════════════════════════
# App
# ═════════════════════════════════════════════════════════════════════════════
# URL pública del sitio — usada para metadataBase en OG/Twitter tags
# Formato local: http://localhost:3000
# Formato production: https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=
